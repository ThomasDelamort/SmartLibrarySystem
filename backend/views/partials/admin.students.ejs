<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Students</title>
</head>
<body>

<!-- ── Confirm Modal ──────────────────────────────────────────────────────── -->
<div id="studentModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:9999;align-items:center;justify-content:center;">
    <div style="background:#fff;border-radius:12px;padding:28px 24px;width:340px;box-shadow:0 8px 32px rgba(0,0,0,.18);">
        <div style="font-size:15px;font-weight:600;color:#0f172a;margin-bottom:8px;" id="studentModalTitle">Confirm Action</div>
        <div style="font-size:13px;color:#64748b;margin-bottom:22px;" id="studentModalMsg">Are you sure?</div>
        <div style="display:flex;gap:10px;justify-content:flex-end;">
            <button onclick="closeStudentModal()"
                    style="padding:8px 18px;border-radius:8px;border:1px solid #e2e8f0;background:#f8fafc;font-size:13px;cursor:pointer;color:#374151;">
                Cancel
            </button>
            <button id="studentModalConfirm"
                    style="padding:8px 18px;border-radius:8px;border:none;background:#e11d48;color:#fff;font-size:13px;cursor:pointer;font-weight:500;">
                Confirm
            </button>
        </div>
    </div>
</div>

<div class="sec">
    <div class="sec-label">Students</div>

    <!-- Search -->
    <div class="panel mb-10">
        <form method="POST" action="/Admin" style="display:flex;gap:8px;">
            <input type="hidden" name="section" value="students">

            <input type="text" name="q" placeholder="Search by name, email, ID..."
                   value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>"
                   style="flex:1;font-size:12px;padding:7px 10px;border:1px solid var(--border);border-radius:8px;background:#f8fafc;color:var(--text-primary);">

            <button type="submit"
                    style="background:#0f172a;color:white;border:none;border-radius:8px;padding:7px 14px;font-size:12px;cursor:pointer;">
                <i class="ti ti-search"></i> Search
            </button>
        </form>
    </div>

    <!-- Students Table -->
    <div class="panel">
        <div class="panel-hdr">
            <div class="panel-title">
                <i class="ti ti-users"></i> All Students
            </div>

            <span style="font-size:11px;color:var(--text-muted)">
                <%= Array.isArray(students) ? students.length : 0 %> total
            </span>
        </div>

        <% if (!Array.isArray(students) || students.length === 0) { %>
        <p style="font-size:12px;color:var(--text-muted)">No students found.</p>
        <% } else { %>

        <div style="overflow-x:auto;">
            <table style="width:100%;border-collapse:collapse;font-size:12px;">
                <thead>
                <tr style="background:#f8fafc;">
                    <th style="padding:10px 12px;text-align:left;">Student</th>
                    <th style="padding:10px 12px;text-align:left;">ID</th>
                    <th style="padding:10px 12px;text-align:left;">Email</th>
                    <th style="padding:10px 12px;text-align:left;">Fines</th>
                    <th style="padding:10px 12px;text-align:left;">Borrow</th>
                    <th style="padding:10px 12px;text-align:left;">Actions</th>
                </tr>
                </thead>

                <tbody>
                <% students.forEach(function(student) {
                const firstInitial = student.firstName ? student.firstName.charAt(0) : '';
                const lastInitial = student.lastName ? student.lastName.charAt(0) : '';
                %>

                <tr style="border-bottom:1px solid var(--border);">
                    <td style="padding:10px 12px;">
                        <div class="acct-row" style="padding:0;border:none;">
                            <div class="avatar av-blue">
                                <%= firstInitial %><%= lastInitial %>
                            </div>
                            <div>
                                <div class="acct-name">
                                    <%= student.firstName || '' %> <%= student.lastName || '' %>
                                </div>
                            </div>
                        </div>
                    </td>

                    <td style="padding:10px 12px;color:var(--text-secondary);">
                        <%= student.studentId || '' %>
                    </td>

                    <td style="padding:10px 12px;color:var(--text-secondary);">
                        <%= student.email || '' %>
                    </td>

                    <td style="padding:10px 12px;">
                        <span style="color:<%= (student.fines || 0) > 0 ? '#e11d48' : '#16a34a' %>;font-weight:600;">
                            $<%= student.fines || 0 %>
                        </span>
                    </td>

                    <td style="padding:10px 12px;">
                        <span class="badge <%= student.canBorrow ? 'badge-green' : 'badge-warn' %>">
                            <%= student.canBorrow ? 'true' : 'false' %>
                        </span>
                    </td>

                    <td style="padding:10px 12px;">
                        <div style="display:flex;gap:6px;">

                            <!-- Revoke / Restore button -->
                            <button id="toggle-btn-<%= student._id %>"
                                    data-id="<%= student._id %>"
                                    data-canborrow="<%= student.canBorrow %>"
                                    onclick="confirmToggle(this)"
                                    style="font-size:11px;padding:5px 10px;border-radius:6px;border:1px solid var(--border);background:white;cursor:pointer;">
                                <%= student.canBorrow ? 'Revoke' : 'Restore' %>
                            </button>

                            <!-- Delete button -->
                            <button data-id="<%= student._id %>"
                                    data-name="<%= student.firstName %> <%= student.lastName %>"
                                    onclick="confirmDeleteStudent(this)"
                                    style="font-size:11px;padding:5px 10px;border-radius:6px;border:1px solid #fecdd3;background:#fff1f2;color:#e11d48;cursor:pointer;">
                                Delete
                            </button>

                        </div>
                    </td>
                </tr>

                <% }); %>
                </tbody>
            </table>
        </div>

        <% } %>
    </div>
</div>

<script>
    /* ── Modal helpers ────────────────────────────────────────────────────────── */
    function openStudentModal(title, msg, onConfirm, confirmLabel, confirmColor) {
        document.getElementById('studentModalTitle').textContent   = title;
        document.getElementById('studentModalMsg').textContent     = msg;
        const btn = document.getElementById('studentModalConfirm');
        btn.textContent    = confirmLabel || 'Confirm';
        btn.style.background = confirmColor || '#e11d48';
        btn.onclick        = () => { closeStudentModal(); onConfirm(); };
        const modal = document.getElementById('studentModal');
        modal.style.display = 'flex';
    }

    function closeStudentModal() {
        document.getElementById('studentModal').style.display = 'none';
    }

    // Close on backdrop click
    document.getElementById('studentModal').addEventListener('click', function(e) {
        if (e.target === this) closeStudentModal();
    });

    /* ── Revoke / Restore ─────────────────────────────────────────────────────── */
    function confirmToggle(btn) {
        const id        = btn.dataset.id;
        const canBorrow = btn.dataset.canborrow === 'true';
        const action    = canBorrow ? 'Revoke' : 'Restore';
        const msg       = canBorrow
            ? 'This will prevent the student from borrowing books.'
            : 'This will allow the student to borrow books again.';

        openStudentModal(
            `${action} borrowing?`, msg,
            () => doToggle(id, btn),
            action,
            canBorrow ? '#d97706' : '#16a34a'
        );
    }

    async function doToggle(id, btn) {
        try {
            const res  = await fetch(`/Admin/Students/ToggleBorrow/${id}`, { method: 'POST' });
            const data = await res.json();
            if (!data.success) return alert('Failed to update student.');

            // Update badge and button in-place — no page reload
            const badge = document.getElementById(`borrow-badge-${id}`);
            if (data.canBorrow) {
                badge.textContent  = 'true';
                badge.className    = 'badge badge-green';
                btn.textContent    = 'Revoke';
                btn.dataset.canborrow = 'true';
            } else {
                badge.textContent  = 'false';
                badge.className    = 'badge badge-warn';
                btn.textContent    = 'Restore';
                btn.dataset.canborrow = 'false';
            }
        } catch (err) {
            alert('Network error. Please try again.');
        }
    }

    /* ── Delete student ───────────────────────────────────────────────────────── */
    function confirmDeleteStudent(btn) {
        const id   = btn.dataset.id;
        const name = btn.dataset.name;
        openStudentModal(
            'Delete student?',
            `"${name}" will be permanently removed. This cannot be undone.`,
            () => doDeleteStudent(id),
            'Delete',
            '#e11d48'
        );
    }

    async function doDeleteStudent(id) {
        try {
            const res  = await fetch(`/Admin/Students/Delete/${id}`, { method: 'POST' });
            const data = await res.json();
            if (!data.success) return alert('Failed to delete student.');

            // Remove the row from the table
            const row = document.getElementById(`student-row-${id}`);
            if (row) row.remove();

            // Update total count
            const rows  = document.querySelectorAll('#studentsTableBody tr');
            const spans = document.querySelectorAll('.panel-hdr .panel-title + span, .panel-hdr span[style]');
            // Find the count badge near "All Students"
            document.querySelectorAll('.panel-hdr span').forEach(s => {
                if (s.textContent.includes('total')) {
                    s.textContent = `${rows.length} total`;
                }
            });
        } catch (err) {
            alert('Network error. Please try again.');
        }
    }
</script>


</body>
</html>