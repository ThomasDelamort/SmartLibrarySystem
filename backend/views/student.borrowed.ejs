<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>My Borrowed Books - Smart Library</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/styles/style.css">
    <link rel="stylesheet" href="/styles/layout.css">
</head>

<body>

<%- include("partials/header.ejs") %>

<div class="container-fluid mt-4">
    <div class="container">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold mb-0">My Borrowed Books</h2>
            <span class="badge bg-dark fs-6"><%= transactions.length %> Active</span>
        </div>

        <% if (transactions.length === 0) { %>
        <div class="text-center mt-5">
            <p class="text-muted fs-5">You have no borrowed books at the moment.</p>
            <a href="/Students" class="btn btn-outline-dark mt-2">Browse Books</a>
        </div>
        <% } %>

        <div class="d-flex flex-column gap-3">
            <% transactions.forEach(txn => { %>
            <div class="card border-0 shadow-sm p-3">
                <div class="row align-items-center">

                    <div class="col-md-1 text-center">
                        <img src="<%= txn.book.image %>"
                             alt="<%= txn.book.title %>"
                             class="img-fluid rounded"
                             style="max-height: 120px; object-fit: cover;">
                    </div>

                    <div class="col-md-6">
                        <h5 class="fw-bold mb-1"><%= txn.book.title %></h5>
                        <p class="text-muted mb-1"><%= txn.book.author %></p>
                        <small class="text-muted">
                            Borrowed: <strong><%= new Date(txn.borrowDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></strong>
                        </small>
                        <br>
                        <small class="text-muted">
                            Due: <strong><%= new Date(txn.dueDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></strong>
                        </small>
                    </div>

                    <div class="col-md-2">
                            <span class="badge <%= txn.status === 'overdue' ? 'bg-danger' : 'bg-success' %> fs-6">
                                <%= txn.status.charAt(0).toUpperCase() + txn.status.slice(1) %>
                            </span>
                    </div>

                    <div class="col-md-3">
                        <% if (txn.pendingReturn) { %>
                        <button class="btn btn-secondary w-100" disabled>
                            Return Pending...
                        </button>
                        <% } else { %>
                        <form action="/Students/Return" method="POST">
                            <input type="hidden" name="transactionId" value="<%= txn._id %>">
                            <button type="submit" class="btn btn-outline-dark w-100">
                                Return
                            </button>
                        </form>
                        <% } %>
                    </div>

                </div>
            </div>
            <% }) %>
        </div>

    </div>
</div>


<div style="margin-top: 50vh;">
    <section class="card-footer">
        <footer>

            <ul class="social_icon col-md">
                <li><a href="#"><ion-icon name="logo-facebook"></ion-icon></a></li>
                <li><a href="#"><ion-icon name="logo-discord"></ion-icon></a></li>
                <li><a href="#"><ion-icon name="logo-linkedin"></ion-icon></a></li>
                <li><a href="#"><ion-icon name="logo-instagram"></ion-icon></a></li>
                <li><a href="#"><ion-icon name="logo-github"></ion-icon></a></li>
            </ul>

            <ul class="menu">
                <li><a href="/">Home</a></li>
                <li><a href="/About">About</a></li>
                <li><a href="/Contact">Services</a></li>
                <li><a href="#">Team</a></li>
                <li><a href="/Contact">Contact</a></li>
            </ul>

            <p class="copyright">
                © <%= new Date().getFullYear() %> SmartLibSys 📚
            </p>

        </footer>
    </section>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
<script type="module" src="https://unpkg.com/ionicons@5.5.2/dist/ionicons/ionicons.esm.js"></script>
<script nomodule src="https://unpkg.com/ionicons@5.5.2/dist/ionicons/ionicons.js"></script>
</body>
</html>