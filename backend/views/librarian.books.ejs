<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Librarian Books</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/styles/layout.css">
    <link rel="stylesheet" href="/styles/librarian.css">
    <link rel="stylesheet" href="/styles/librarian.book.css">
</head>
<body>

<%- include("partials/librarian.header.ejs") %>

<div class="container-fluid mt-4">
    <div class="container books-container">

        <div class="books-header">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
                <div>
                    <h2 class="fw-bold mb-1">
                        Books
                    </h2>
                </div>

                <a href="/Librarian-Books/Add" class="btn btn-dark btn-lg rounded-4 px-4">
                    Add New Book
                </a>
            </div>
        </div>

        <div class="books-list">
            <div class="d-flex flex-column gap-3">

                <% books.forEach(book => { %>
                <div class="book-item">
                    <div class="row align-items-center">

                        <div class="col-md-2 text-center">
                            <img
                                    src="<%= book.image %>"
                                    alt="<%= book.title %>"
                                    class="img-container"
                            >
                        </div>
                        <div class="col-md-7">
                            <div class="title-status">
                                <h5 class="book-title">
                                    <%= book.title %>
                                </h5>

                                <span class="status-pill
                                    <%= book.status === 'available'
                                        ? 'status-available'
                                        : 'status-borrowed'
                                    %>">
                                    <%= book.status %>
                                </span>
                            </div>
                            <p class="book-meta">
                                <strong>Author:</strong>
                                <%= Array.isArray(book.author)
                                ? book.author.join(", ")
                                : book.author
                                %>
                            </p>

                            <div id="jawkey">
                                <p class="mb-3 book-info">
                                    <strong>Category:</strong>
                                    <% book.category.forEach((cat) => { %>
                                    <span class="cat"><%= cat %></span>
                                    <% }) %>
                                </p>
                            </div>

                        </div>

                        <div class="col-md-3">
                            <div class="book-actions d-flex flex-column gap-2">
                                <a href="/Librarian-Books/Edit/<%= book._id %>" class="btn btn-outline-primary">Edit</a>
                                <form action="/Librarian-Books/Delete/<%= book._id %>" method="POST">
                                    <button type="submit" class="btn btn-outline-danger w-100"
                                            onclick="return confirm('Are you sure you want to delete this book?')">
                                        Delete
                                    </button>
                                </form>
                            </div>
                        </div>

                    </div>
                </div>
                <% }) %>

            </div>


            <div class="d-flex justify-content-center mt-5">
                <nav>
                    <ul class="pagination">
                        <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
                            <a
                                    class="page-link"
                                    href="?page=<%= currentPage - 1 %>&q=<%= searchQuery %>"
                            >
                                Previous
                            </a>
                        </li>

                        <% for(let i = 1; i <= totalPages; i++) { %>
                        <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                            <a
                                    class="page-link"
                                    href="?page=<%= i %>&q=<%= searchQuery %>"
                            >
                                <%= i %>
                            </a>
                        </li>
                        <% } %>


                        <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
                            <a
                                    class="page-link"
                                    href="?page=<%= currentPage + 1 %>&q=<%= searchQuery %>"
                            >
                                Next
                            </a>
                        </li>
                    </ul>
                </nav>
            </div>
        </div>
    </div>
</div>


<section class="card-footer">
    <footer>
        <ul class="social_icon col-md">
            <li><a href="#"><ion-icon name="logo-facebook"></ion-icon></a></li>
            <li><a href="#"><ion-icon name="logo-discord"></ion-icon></a></li>
            <li><a href="#"><ion-icon name="logo-linkedin"></ion-icon></a></li>
            <li><a href="#"><ion-icon name="logo-instagram"></ion-icon></a></li>
            <li><a href="#"><ion-icon name="logo-github"></ion-icon></a></li>
        </ul>

        <ul class="menu">
            <li><a href="/">Home</a></li>
            <li><a href="/About">About</a></li>
            <li><a href="/Contact">Services</a></li>
            <li><a href="#">Team</a></li>
            <li><a href="/Contact">Contact</a></li>
        </ul>

        <p class="copyright">
            © <%= new Date().getFullYear() %> SmartLibSys 📚
        </p>
    </footer>
</section>



<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
<script type="module" src="https://unpkg.com/ionicons@5.5.2/dist/ionicons/ionicons.esm.js"></script>
<script nomodule src="https://unpkg.com/ionicons@5.5.2/dist/ionicons/ionicons.js"></script>
</body>
</html>