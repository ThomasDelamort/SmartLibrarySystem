<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Liked Books - Smart Library</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/styles/style.css">
    <link rel="stylesheet" href="/styles/layout.css">
</head>

<body>

<%- include("partials/header.ejs") %>

<div class="container-fluid mt-4">
    <div class="container">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold mb-0">Liked Books</h2>
            <span class="badge bg-dark fs-6"><%= likedBooks.length %> Books</span>
        </div>

        <% if (likedBooks.length === 0) { %>
        <div class="text-center mt-5">
            <p class="text-muted fs-5">You haven't liked any books yet.</p>
            <a href="/Students" class="btn btn-outline-dark mt-2">Browse Books</a>
        </div>
        <% } %>

        <div class="row g-4">
            <% likedBooks.forEach(function(book) { %>
            <div class="col-md-4">
                <div class="position-relative">

                    <form action="/Students/Like/<%= book._id %>" method="POST"
                          style="position:absolute; top:10px; right:10px; z-index:10;">
                        <button type="submit" class="btn btn-sm p-1"
                                style="background:white; border:none; font-size:1.2rem; line-height:1;">
                            ⭐
                        </button>
                    </form>

                    <a href="/Students/Book/<%= encodeURIComponent(book.title) %>"
                       class="text-decoration-none text-dark">
                        <div class="card h-100 book-card border-0 shadow-sm">
                            <div class="d-flex h-100">
                                <img src="<%= book.image %>"
                                     alt="<%= book.title %>"
                                     class="img-thumbnail"
                                     style="width:100px; object-fit:cover;">
                                <div class="card-body d-flex flex-column py-3">
                                    <h6 class="card-title mb-2 fw-bold"><%= book.title %></h6>
                                    <p class="mb-1 text-muted" style="font-size:0.85rem;">
                                        <strong>Author:</strong> <%= book.author.join(", ") %>
                                    </p>
                                    <p class="mb-2 text-muted" style="font-size:0.85rem;">
                                        <% book.category.forEach(function(cat) { %>
                                        <span class="cat"><%= cat %></span>
                                        <% }) %>
                                    </p>
                                    <span class="status-pill mt-auto
                                            <%= book.status === 'available' ? 'status-available' : 'status-borrowed' %>">
                                            <%= book.status %>
                                        </span>
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
            </div>
            <% }) %>
        </div>

    </div>
</div>

<div style="margin-top: 50vh">
    <section class="card-footer mt-5">
        <footer>
            <ul class="social_icon col-md">
                <li><a href="#"><ion-icon name="logo-facebook"></ion-icon></a></li>
                <li><a href="#"><ion-icon name="logo-discord"></ion-icon></a></li>
                <li><a href="#"><ion-icon name="logo-linkedin"></ion-icon></a></li>
                <li><a href="#"><ion-icon name="logo-instagram"></ion-icon></a></li>
                <li><a href="#"><ion-icon name="logo-github"></ion-icon></a></li>
            </ul>
            <ul class="menu">
                <li><a href="/">Home</a></li>
                <li><a href="/About">About</a></li>
                <li><a href="/Contact">Services</a></li>
                <li><a href="#">Team</a></li>
                <li><a href="/Contact">Contact</a></li>
            </ul>
            <p class="copyright">© <%= new Date().getFullYear() %> SmartLibSys 📚</p>
        </footer>
    </section>
</div>


<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
<script type="module" src="https://unpkg.com/ionicons@5.5.2/dist/ionicons/ionicons.esm.js"></script>
<script nomodule src="https://unpkg.com/ionicons@5.5.2/dist/ionicons/ionicons.js"></script>
</body>
</html>