<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Add Book</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/styles/layout.css">
    <link rel="stylesheet" href="/styles/librarian.css">
</head>
<body>

<%- include("partials/librarian.header.ejs") %>

<div class="container-fluid mt-4">
    <div class="container" style="max-width: 700px;">

        <div class="d-flex align-items-center gap-3 mb-4">
            <a href="/Librarian-Books" class="btn btn-outline-dark">← Back</a>
            <h2 class="fw-bold mb-0">Add New Book</h2>
        </div>

        <div class="card border-0 shadow-sm p-4">
            <form action="/Librarian-Books/Add" method="POST" enctype="multipart/form-data">

                <div class="mb-3">
                    <label class="form-label fw-semibold">Title</label>
                    <input type="text" name="title" class="form-control" required>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Author <small class="text-muted">(comma separated)</small></label>
                    <input type="text" name="author" class="form-control" placeholder="e.g. James Clear, John Doe" required>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Category <small class="text-muted">(comma separated)</small></label>
                    <input type="text" name="category" class="form-control" placeholder="e.g. Self Help, Business" required>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Image URL</label>
                    <input type="file" name="image" class="form-control" accept="image/*" required>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Description</label>
                    <textarea name="description" class="form-control" rows="4" required></textarea>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">ISBN</label>
                    <input type="text" name="isbn" class="form-control">
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Publisher</label>
                    <input type="text" name="publisher" class="form-control">
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Published Year</label>
                    <input type="number" name="publishedYear" class="form-control" min="1000" max="<%= new Date().getFullYear() %>">
                </div>

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-dark px-4">Add Book</button>
                    <a href="/Librarian-Books" class="btn btn-outline-secondary px-4">Cancel</a>
                </div>

            </form>
        </div>

    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>