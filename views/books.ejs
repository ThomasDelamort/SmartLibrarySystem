<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Books</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/styles/style.css">
    <link rel="stylesheet" href="/styles/layout.css">
    <link rel="stylesheet" href="/styles/transition.css">
</head>

<body>

<%- include("partials/header.ejs") %>

<div class="container-fluid mt-4">
    <div class="row g-4">

        <!-- FILTER -->
        <div class="col-md-2">
            <div class="filter-card">
                <div class="filter-header text-center">
                    <h4 class="fw-medium mb-0">Filter</h4>
                </div>
                <div class="filter-body">
                    <h5 class="mb-3">Categories</h5>
                    <form method="GET" action="/BookFilter">
                        <input type="hidden" name="page" value="1">

                        <% ["Fantasy","Science Fiction","Romance","Horror","Business","Self Help","Biography"].forEach(cat => { %>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="category" value="<%= cat %>" id="<%= cat %>">
                            <label class="form-check-label" for="<%= cat %>"><%= cat %></label>
                        </div>
                        <% }) %>

                        <button type="submit" class="btn btn-outline-success mt-3 w-100">
                            Apply Filter
                        </button>
                    </form>

                </div>
            </div>
        </div>

        <!-- BOOKS -->
        <div class="col-md-10">
            <div class="dashboard-container">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h3 class="fw-bold mb-1">Books</h3>
                </div>
                <div class="row g-4">

                    <% books.forEach(book => { %>
                    <div class="col-md-4">
                        <a href="/Books/Book/<%= encodeURIComponent(book.title) %>"
                           class="text-decoration-none text-dark">
                            <div class="card h-100 book-card" id="book-card">
                                <div class="d-flex h-100">
                                    <img src="<%= book.image %>"
                                         alt="<%= book.title %>"
                                         class="img-thumbnail">
                                    <div class="card-body d-flex flex-column py-3">
                                        <h6 class="card-title mb-2">
                                            <%= book.title %>
                                        </h6>
                                        <p class="mb-1 book-info">
                                            <strong>Author:</strong>
                                            <%= book.author.join(", ") %>
                                        </p>
                                        <div id="chicken">
                                            <p class="mb-3 book-info">
                                                <strong>Category:</strong>
                                                <% book.category.forEach((cat) => { %>
                                                <span class="cat"><%= cat %></span>
                                                <% }) %>
                                            </p>
                                        </div>


                                        <span class="status-pill
                                            <%= book.status === 'available'
                                                ? 'status-available'
                                                : 'status-borrowed'
                                            %>">
                                            <%= book.status %>
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </a>
                    </div>
                    <% }) %>


                </div>


                <div class="d-flex justify-content-center mt-5">
                    <nav>
                        <ul class="pagination">

                            <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
                                <a class="page-link" href="/Books?page=<%= currentPage - 1 %>">
                                    Previous
                                </a>
                            </li>

                            <% for (let i = 1; i <= totalPages; i++) { %>
                            <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                                <a class="page-link" href="/Books?page=<%= i %>">
                                    <%= i %>
                                </a>
                            </li>
                            <% } %>

                            <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
                                <a class="page-link" href="/Books?page=<%= currentPage + 1 %>">
                                    Next
                                </a>
                            </li>
                        </ul>
                    </nav>
                </div>
            </div>
        </div>
    </div>
</div>


<section class="card-footer">
    <footer>

        <ul class="social_icon col-md">
            <li><a href="#"><ion-icon name="logo-facebook"></ion-icon></a></li>
            <li><a href="#"><ion-icon name="logo-discord"></ion-icon></a></li>
            <li><a href="#"><ion-icon name="logo-linkedin"></ion-icon></a></li>
            <li><a href="#"><ion-icon name="logo-instagram"></ion-icon></a></li>
            <li><a href="#"><ion-icon name="logo-github"></ion-icon></a></li>
        </ul>

        <ul class="menu">
            <li><a href="/">Home</a></li>
            <li><a href="/About">About</a></li>
            <li><a href="/Contact">Services</a></li>
            <li><a href="#">Team</a></li>
            <li><a href="/Contact">Contact</a></li>
        </ul>

        <p class="copyright">
            © <%= new Date().getFullYear() %> SmartLibSys 📚
        </p>

    </footer>
</section>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>

<script type="module" src="https://unpkg.com/ionicons@5.5.2/dist/ionicons/ionicons.esm.js"></script>
<script nomodule src="https://unpkg.com/ionicons@5.5.2/dist/ionicons/ionicons.js"></script>

<script src="/transition.js"></script>

</body>
</html>