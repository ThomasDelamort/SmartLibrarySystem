<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Edit Book</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/styles/layout.css">
    <link rel="stylesheet" href="/styles/librarian.css">
</head>
<body>

<%- include("partials/librarian.header.ejs") %>

<div class="container-fluid mt-4">
    <div class="container" style="max-width: 700px;">

        <div class="d-flex align-items-center gap-3 mb-4">
            <a href="/Librarian-Books" class="btn btn-outline-dark">← Back</a>
            <h2 class="fw-bold mb-0">Edit Book</h2>
        </div>

        <div class="card border-0 shadow-sm p-4">
            <form action="/Librarian-Books/Edit/<%= book._id %>" method="POST" enctype="multipart/form-data">

                <div class="mb-3">
                    <label class="form-label fw-semibold">Title</label>
                    <input type="text" name="title" class="form-control" value="<%= book.title %>" required>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Author <small class="text-muted">(comma separated)</small></label>
                    <input type="text" name="author" class="form-control" value="<%= Array.isArray(book.author) ? book.author.join(', ') : book.author %>" required>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Category <small class="text-muted">(comma separated)</small></label>
                    <input type="text" name="category" class="form-control" value="<%= Array.isArray(book.category) ? book.category.join(', ') : book.category %>" required>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Image URL</label>
                    <img src="<%= book.image %>" alt="Current Cover" style="height:80px;" class="mb-2 d-block">
                    <input type="file" name="image" class="form-control" accept="image/*">
                    <small class="text-muted">Leave empty to keep current image</small>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Description</label>
                    <textarea name="description" class="form-control" rows="4" required><%= book.description %></textarea>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">ISBN</label>
                    <input type="text" name="isbn" class="form-control" value="<%= book.isbn || '' %>">
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Publisher</label>
                    <input type="text" name="publisher" class="form-control" value="<%= book.publisher || '' %>">
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Published Year</label>
                    <input type="number" name="publishedYear" class="form-control" value="<%= book.publishedYear || '' %>" min="1000" max="<%= new Date().getFullYear() %>">
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Status</label>
                    <select name="status" class="form-select">
                        <option value="available" <%= book.status === 'available' ? 'selected' : '' %>>Available</option>
                        <option value="borrowed" <%= book.status === 'borrowed' ? 'selected' : '' %>>Borrowed</option>
                        <option value="overdue" <%= book.status === 'overdue' ? 'selected' : '' %>>Overdue</option>
                        <option value="lost" <%= book.status === 'lost' ? 'selected' : '' %>>Lost</option>
                        <option value="damaged" <%= book.status === 'damaged' ? 'selected' : '' %>>Damaged</option>
                    </select>
                </div>

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-dark px-4">Save Changes</button>
                    <a href="/Librarian-Books" class="btn btn-outline-secondary px-4">Cancel</a>
                </div>

            </form>
        </div>

    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>