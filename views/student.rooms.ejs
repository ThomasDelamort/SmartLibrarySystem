<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Reserve a Room - Smart Library</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/styles/style.css">
    <link rel="stylesheet" href="/styles/layout.css">
    <link rel="stylesheet" href="/styles/transition.css">
</head>

<body>

<%- include("partials/header.ejs") %>

<div class="container-fluid mt-4">
    <div class="container">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h3 class="fw-bold mb-0">Reserve a Room</h3>
        </div>

        <% if (rooms.length === 0) { %>
        <p class="text-muted">No rooms available at the moment.</p>
        <% } %>

        <div class="row g-4">
            <% rooms.forEach(room => { %>
            <div class="col-md-4">
                <div class="card h-100 shadow-sm">
                    <div class="card-body d-flex flex-column gap-2">

                        <div class="d-flex justify-content-between align-items-center">
                            <h5 class="fw-bold mb-0">Room <%= room.number %></h5>
                            <span class="badge <%= room.status === 'available' ? 'bg-success' : room.status === 'reserved' ? 'bg-warning text-dark' : room.status === 'occupied' ? 'bg-danger' : 'bg-secondary' %>">
                                    <%= room.status %>
                                </span>
                        </div>

                        <p class="text-muted mb-0">
                            <strong>Capacity:</strong> <%= room.capacity %> persons
                        </p>

                        <% if (room.status === 'available') { %>
                        <button type="button"
                                class="btn btn-outline-primary mt-auto"
                                data-bs-toggle="modal"
                                data-bs-target="#reserveModal"
                                data-room-id="<%= room._id %>"
                                data-room-number="<%= room.number %>">
                            Reserve
                        </button>
                        <% } else { %>
                        <button class="btn btn-secondary mt-auto" disabled>
                            Unavailable
                        </button>
                        <% } %>

                    </div>
                </div>
            </div>
            <% }) %>
        </div>

    </div>
</div>

<!-- Reserve Modal -->
<div class="modal fade" id="reserveModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Reserve Room <span id="modalRoomNumber"></span></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <form action="/Students/Rooms/Reserve" method="POST">
                <input type="hidden" name="roomId" id="modalRoomId">

                <div class="modal-body d-flex flex-column gap-3">

                    <div>
                        <label class="form-label">Date</label>
                        <input type="date" name="reservationDate" class="form-control" required>
                    </div>

                    <div class="row g-2">
                        <div class="col">
                            <label class="form-label">Start Time</label>
                            <input type="time" name="startTime" class="form-control" required>
                        </div>
                        <div class="col">
                            <label class="form-label">End Time</label>
                            <input type="time" name="endTime" class="form-control" required>
                        </div>
                    </div>

                    <div>
                        <label class="form-label">Purpose</label>
                        <input type="text" name="purpose" class="form-control" maxlength="300" placeholder="e.g. Group Study">
                    </div>

                    <div>
                        <label class="form-label">Number of Attendees</label>
                        <input type="number" name="attendeesCount" class="form-control" min="1" value="1" required>
                    </div>

                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Confirm Reservation</button>
                </div>
            </form>

        </div>
    </div>
</div>

<section class="card-footer">
    <footer>
        <ul class="social_icon col-md">
            <li><a href="#"><ion-icon name="logo-facebook"></ion-icon></a></li>
            <li><a href="#"><ion-icon name="logo-discord"></ion-icon></a></li>
            <li><a href="#"><ion-icon name="logo-linkedin"></ion-icon></a></li>
            <li><a href="#"><ion-icon name="logo-instagram"></ion-icon></a></li>
            <li><a href="#"><ion-icon name="logo-github"></ion-icon></a></li>
        </ul>
        <ul class="menu">
            <li><a href="/">Home</a></li>
            <li><a href="/About">About</a></li>
            <li><a href="/Contact">Services</a></li>
            <li><a href="#">Team</a></li>
            <li><a href="/Contact">Contact</a></li>
        </ul>
        <p class="copyright">© <%= new Date().getFullYear() %> SmartLibSys 📚</p>
    </footer>
</section>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
<script type="module" src="https://unpkg.com/ionicons@5.5.2/dist/ionicons/ionicons.esm.js"></script>
<script nomodule src="https://unpkg.com/ionicons@5.5.2/dist/ionicons/ionicons.js"></script>
<script src="/transition.js"></script>

<script>
    document.querySelectorAll("[data-room-id]").forEach(btn => {
        btn.addEventListener("click", () => {
            document.getElementById("modalRoomId").value = btn.dataset.roomId;
            document.getElementById("modalRoomNumber").textContent = btn.dataset.roomNumber;
        });
    });
</script>

</body>
</html>