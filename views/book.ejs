<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= book.title %> - Smart Library</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/styles/style.css">
    <link rel="stylesheet" href="/styles/layout.css">
    <link rel="stylesheet" href="/styles/book.css">
    <script src="/js/qrcode.min.js"></script>
</head>

<body>

<%- include("partials/header.ejs") %>

<div class="container">
    <div class="book-container mx-auto" style="max-width: 1280px;">
        <div class="d-flex align-items-start gap-5 book-wrapper">

            <div>
                <img src="<%= book.image %>"
                     alt="<%= book.title %>"
                     id="book-image"
                     class="img-fluid">
            </div>

            <div class="flex-grow-1">

                <div class="title-status">
                    <h1 class="book-title"><%= book.title %></h1>
                    <span class="status-pill
                        <%= book.status === 'available' ? 'status-available' : 'status-borrowed' %>">
                        <%= book.status %>
                    </span>
                    <form action="/Students/Like/<%= book._id %>" method="POST" class="d-inline">
                        <button type="submit" class="btn btn-sm"
                                style="font-size:1.5rem; background:none; border:none; padding:0;">
                            <%= likedBooks.includes(book._id.toString()) ? '⭐' : '☆' %>
                        </button>
                    </form>
                </div>

                <p class="book-meta mb-1"><strong>Likes:</strong> <%= book.likes %></p>

                <p class="book-meta mb-2"><strong>Author:</strong> <%= book.author %></p>
                <p class="book-meta mb-3"><strong>Category:</strong> <%= book.category %></p>
                <hr>

                <div class="book-description">
                    <h5 class="mb-3">Description</h5>
                    <p><%= book.description %></p>
                </div>

                <div class="book-actions d-flex gap-3 flex-wrap">

                    <% if (book.status !== 'borrowed') { %>

                    <% if (loggedIn) { %>
                    <button type="button"
                            class="btn btn-outline-primary btn-lg"
                            data-bs-toggle="modal"
                            data-bs-target="#borrowModal">
                        Borrow Book
                    </button>

                    <% } else { %>
                    <form action="/Submit" method="POST">
                        <input type="hidden" name="id" value="<%= book._id %>">
                        <input type="hidden" name="action" value="borrow">

                        <button type="submit"
                                class="btn btn-outline-primary btn-lg">
                            Borrow Book
                        </button>
                    </form>
                    <% } %>


                    <% } else { %>
                    <button class="btn btn-secondary btn-lg" disabled>
                        Unavailable
                    </button>
                    <% } %>

                    <% if (loggedIn) { %>

                    <button type="button"
                            class="btn btn-outline-success btn-lg"
                            data-bs-toggle="modal"
                            data-bs-target="#bagModal">
                        🛒 Add to Bag
                    </button>

                    <% } else { %>

                    <form action="/Submit" method="POST">
                        <input type="hidden" name="id" value="<%= book._id %>">
                        <input type="hidden" name="action" value="bag">

                        <button type="submit"
                                class="btn btn-outline-success btn-lg">
                            🛒 Add to Bag
                        </button>
                    </form>

                    <% } %>

                    <form action="/Submit" method="POST">
                        <input type="hidden" name="id" value="<%= book.id %>">
                        <button type="submit"
                                name="action"
                                value="downloadPdf"
                                class="btn btn-danger btn-lg">
                            Download PDF
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="space"></div>

<section class="card-footer">
    <footer>
        <ul class="social_icon col-md">
            <li><a href="#"><ion-icon name="logo-facebook"></ion-icon></a></li>
            <li><a href="#"><ion-icon name="logo-discord"></ion-icon></a></li>
            <li><a href="#"><ion-icon name="logo-linkedin"></ion-icon></a></li>
            <li><a href="#"><ion-icon name="logo-instagram"></ion-icon></a></li>
            <li><a href="#"><ion-icon name="logo-github"></ion-icon></a></li>
        </ul>
        <ul class="menu">
            <li><a href="/">Home</a></li>
            <li><a href="/About">About</a></li>
            <li><a href="/Contact">Services</a></li>
            <li><a href="#">Team</a></li>
            <li><a href="/Contact">Contact</a></li>
        </ul>
        <p class="copyright">© <%= new Date().getFullYear() %> SmartLibSys 📚</p>
    </footer>
</section>


<div class="modal fade" id="borrowModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Borrow Book</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <form id="borrowForm" action="/Submit" method="POST">
                <input type="hidden" name="id" value="<%= book.id %>">
                <input type="hidden" name="action" value="borrow">

                <div class="modal-body">

                    <label for="returnDate" class="form-label">Select Return Date</label>
                    <input type="date"
                           id="returnDate"
                           name="dueDate"
                           class="form-control"
                           required>
                    <% if (error) { %>
                    <p class="text-danger text-center mb-3" style="margin-top: 20px;"><%= error %></p>
                    <% } %>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" id="confirmBorrowBtn" class="btn btn-primary">Confirm Borrow</button>
                </div>
            </form>

        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
<script type="module" src="https://unpkg.com/ionicons@5.5.2/dist/ionicons/ionicons.esm.js"></script>
<script nomodule src="https://unpkg.com/ionicons@5.5.2/dist/ionicons/ionicons.js"></script>

<% if (error) { %>
<script>
    document.addEventListener("DOMContentLoaded", () => {
        new bootstrap.Modal(document.getElementById("borrowModal")).show();
    });
</script>
<% } %>

<!-- Add to Bag Modal -->
<div class="modal fade" id="bagModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">🛒 Add to Bag</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form action="/Students/Bag/Add" method="POST">
                <input type="hidden" name="bookId" value="<%= book.id %>">
                <div class="modal-body">
                    <label for="bagDueDate" class="form-label">Select Due Date</label>
                    <input type="date"
                           id="bagDueDate"
                           name="dueDate"
                           class="form-control"
                           required>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">Add to Bag</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="qrModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content text-center">
            <div class="modal-header border-0 pb-0">
                <div class="w-100">
                    <div style="font-size: 2.5rem;">📚</div>
                    <h5 class="modal-title fw-bold mt-1">Borrow Request Submitted!</h5>
                    <p class="text-muted small mb-0">Show this QR code to the librarian when collecting your book.</p>
                </div>
            </div>
            <div class="modal-body py-3">
                <div class="d-flex justify-content-center mb-3">
                    <div id="qrCodeContainer"
                         style="padding: 12px; border: 2px solid #dee2e6; border-radius: 12px; background: #fff;">
                        <canvas id="qrCanvas"></canvas>
                    </div>
                </div>
                <div id="qrDetails" class="text-start bg-light rounded p-3 small"
                     style="font-family: monospace; font-size: 0.8rem;"></div>
            </div>
            <div class="modal-footer border-0 justify-content-center gap-2 pt-0 pb-4">
                <button type="button" class="btn btn-outline-secondary" id="downloadQrBtn">⬇ Download QR</button>
                <a href="/Students/Borrowed" id="qrDoneBtn" class="btn btn-primary px-4">Done</a>
            </div>
        </div>
    </div>
</div>

<script>
    (function () {
        const borrowForm = document.getElementById('borrowForm');
        const submitBtn = document.getElementById('confirmBorrowBtn');

        borrowForm.addEventListener('submit', async function (e) {
            e.preventDefault();

            const dueDateVal = document.getElementById('returnDate').value;

            submitBtn.disabled = true;
            submitBtn.textContent = 'Submitting…';

            const formData = new FormData(borrowForm);

            const response = await fetch('/Submit', {
                method: 'POST',
                body: new URLSearchParams(formData),
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                redirect: 'follow'
            });

            const finalUrl = response.url || '';
            if (finalUrl.includes('error=')) {
                const url = new URL(finalUrl);
                const errMsg = decodeURIComponent(url.searchParams.get('error') || 'Something went wrong.');
                alert('❌ ' + errMsg);
                submitBtn.disabled = false;
                submitBtn.textContent = 'Confirm Borrow';
                return;
            }

            // Step 4 success — close borrow modal
            bootstrap.Modal.getInstance(document.getElementById('borrowModal'))?.hide();

            // Step 5 — generate QR
            const refNum = 'TXN-' + Date.now() + '-' + Math.floor(Math.random() * 1000);
            const bookTitle = '<%= book.title %>';
            const dueDate = new Date(dueDateVal).toLocaleDateString('en-PH', { year: 'numeric', month: 'long', day: 'numeric' });
            const borrowedOn = new Date().toLocaleDateString('en-PH', { year: 'numeric', month: 'long', day: 'numeric' });

            const qrPayload = JSON.stringify({ ref: refNum, book: bookTitle, dueDate: dueDateVal, status: 'pending' });

            const canvas = document.getElementById('qrCanvas');
            QRCode.toCanvas(canvas, qrPayload, { width: 200, margin: 1, color: { dark: '#1a1a2e', light: '#ffffff' } });

            document.getElementById('qrDetails').innerHTML =
                `<div class="mb-1"><strong>📖 Book:</strong> ${bookTitle}</div>` +
                `<div class="mb-1"><strong>🔖 Reference:</strong> ${refNum}</div>` +
                `<div class="mb-1"><strong>📅 Borrowed On:</strong> ${borrowedOn}</div>` +
                `<div><strong>⏰ Due Date:</strong> ${dueDate}</div>`;

            new bootstrap.Modal(document.getElementById('qrModal')).show();

            // Step 6 — download button
            document.getElementById('downloadQrBtn').onclick = function () {
                const link = document.createElement('a');
                link.download = 'borrow-qr-' + refNum + '.png';
                link.href = canvas.toDataURL('image/png');
                link.click();
            };
        });
    })();
</script>

</body>
</html>