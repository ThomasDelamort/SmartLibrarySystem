<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>My History - Smart Library</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/styles/style.css">
    <link rel="stylesheet" href="/styles/layout.css">
</head>

<body>

<%- include("partials/header.ejs") %>

<div class="container-fluid mt-4">
    <div class="container">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold mb-0">My History</h2>
            <span class="badge bg-dark fs-6"><%= bookHistory.length + roomHistory.length %> Total</span>
        </div>

        <!-- Book History -->
        <h5 class="fw-bold mb-3">Book Transactions</h5>

        <% if (bookHistory.length === 0) { %>
        <p class="text-muted mb-4">No book transaction history.</p>
        <% } %>

        <div class="d-flex flex-column gap-3 mb-5">
            <% bookHistory.forEach(txn => { %>
            <div class="card border-0 shadow-sm p-3">
                <div class="row align-items-center">

                    <div class="col-md-1 text-center">
                        <img src="<%= txn.book.image %>"
                             alt="<%= txn.book.title %>"
                             class="img-fluid rounded"
                             style="max-height: 80px; object-fit: cover;">
                    </div>

                    <div class="col-md-7">
                        <h5 class="fw-bold mb-1"><%= txn.book.title %></h5>
                        <p class="text-muted mb-1"><%= txn.book.author %></p>
                        <small class="text-muted">
                            <%= txn.transactionType === 'return' ? 'Returned' : 'Borrowed' %>:
                            <strong><%= new Date(txn.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></strong>
                        </small>
                        <% if (txn.fineAmount > 0) { %>
                        <br><small class="text-danger">Fine: ₱<%= txn.fineAmount %></small>
                        <% } %>
                    </div>

                    <div class="col-md-4 text-end">
                            <span class="badge <%=
                                txn.status === 'returned' ? 'bg-success' :
                                txn.status === 'cancelled' ? 'bg-secondary' :
                                'bg-danger'
                            %> fs-6">
                                <%= txn.status.charAt(0).toUpperCase() + txn.status.slice(1) %>
                            </span>
                    </div>

                </div>
            </div>
            <% }) %>
        </div>

        <!-- Room History -->
        <h5 class="fw-bold mb-3">Room Reservations</h5>

        <% if (roomHistory.length === 0) { %>
        <p class="text-muted mb-4">No room reservation history.</p>
        <% } %>

        <div class="d-flex flex-column gap-3">
            <% roomHistory.forEach(res => { %>
            <div class="card border-0 shadow-sm p-3">
                <div class="row align-items-center">

                    <div class="col-md-1 text-center">
                        <ion-icon name="business-outline" style="font-size: 2.5rem; color: #6c757d;"></ion-icon>
                    </div>

                    <div class="col-md-7">
                        <h5 class="fw-bold mb-1">Room <%= res.room.number %></h5>
                        <p class="text-muted mb-1">
                            <%= new Date(res.reservationDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %>
                        </p>
                        <small class="text-muted">
                            Time: <strong><%= res.startTime %> - <%= res.endTime %></strong>
                        </small>
                        <% if (res.purpose) { %>
                        <br><small class="text-muted">Purpose: <%= res.purpose %></small>
                        <% } %>
                    </div>

                    <div class="col-md-4 text-end">
                            <span class="badge <%=
                                res.status === 'completed' ? 'bg-success' :
                                res.status === 'cancelled' ? 'bg-secondary' :
                                'bg-danger'
                            %> fs-6">
                                <%= res.status.charAt(0).toUpperCase() + res.status.slice(1) %>
                            </span>
                    </div>

                </div>
            </div>
            <% }) %>
        </div>

    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
<script type="module" src="https://unpkg.com/ionicons@5.5.2/dist/ionicons/ionicons.esm.js"></script>
<script nomodule src="https://unpkg.com/ionicons@5.5.2/dist/ionicons/ionicons.js"></script>
</body>
</html>