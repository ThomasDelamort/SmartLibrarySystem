<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>My Profile - Smart Library</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/styles/style.css">
    <link rel="stylesheet" href="/styles/librarian.css">
</head>

<body>

<%- include("partials/librarian.header.ejs") %>

<div class="container-fluid mt-4">
    <div class="container" style="max-width: 700px;">

        <h2 class="fw-bold mb-4">My Profile</h2>

        <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-danger"><%= error %></div>
        <% } %>
        <% if (typeof success !== 'undefined' && success) { %>
        <div class="alert alert-success"><%= success %></div>
        <% } %>

        <!-- Profile Info Card -->
        <div class="card border-0 shadow-sm p-4 mb-4">
            <div class="d-flex align-items-center gap-4">
                <img src="/images/user.png" alt="profile" style="width: 80px; height: 80px; border-radius: 50%; object-fit: cover;">
                <div>
                    <h4 class="fw-bold mb-0"><%= librarian.firstName %> <%= librarian.lastName %></h4>
                    <small class="text-muted"><%= librarian.librarianId %></small><br>
                    <span class="badge bg-dark mt-1">Librarian</span>
                    <% if (librarian.married) { %>
                    <span class="badge bg-secondary mt-1">Married</span>
                    <% } %>
                </div>
            </div>
        </div>

        <!-- Edit Profile -->
        <div class="card border-0 shadow-sm p-4 mb-4">
            <h5 class="fw-bold mb-3">Edit Profile</h5>
            <form action="/Librarian-Profile/Update" method="POST">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">First Name</label>
                        <input type="text" name="firstName" class="form-control" value="<%= librarian.firstName %>" required>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Last Name</label>
                        <input type="text" name="lastName" class="form-control" value="<%= librarian.lastName %>" required>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Email</label>
                        <input type="email" name="email" class="form-control" value="<%= librarian.email %>" required>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Sex</label>
                        <select name="sex" class="form-select" required>
                            <option value="male" <%= librarian.sex === 'male' ? 'selected' : '' %>>Male</option>
                            <option value="female" <%= librarian.sex === 'female' ? 'selected' : '' %>>Female</option>
                        </select>
                    </div>
                    <div class="col-md-6 d-flex align-items-center gap-2 mt-2">
                        <input type="checkbox" name="married" id="married" class="form-check-input" <%= librarian.married ? 'checked' : '' %>>
                        <label for="married" class="form-check-label fw-semibold">Married</label>
                    </div>
                </div>
                <div class="d-flex justify-content-end mt-3">
                    <button type="submit" class="btn btn-dark px-4">Save Changes</button>
                </div>
            </form>
        </div>

        <!-- Change Password -->
        <div class="card border-0 shadow-sm p-4">
            <h5 class="fw-bold mb-3">Change Password</h5>
            <form action="/Librarian-Profile/ChangePassword" method="POST">
                <div class="d-flex flex-column gap-3">
                    <div>
                        <label class="form-label fw-semibold">Current Password</label>
                        <input type="password" name="currentPassword" class="form-control" required>
                    </div>
                    <div>
                        <label class="form-label fw-semibold">New Password</label>
                        <input type="password" name="newPassword" class="form-control" minlength="6" required>
                    </div>
                    <div>
                        <label class="form-label fw-semibold">Confirm New Password</label>
                        <input type="password" name="confirmPassword" class="form-control" minlength="6" required>
                    </div>
                </div>
                <div class="d-flex justify-content-end mt-3">
                    <button type="submit" class="btn btn-outline-dark px-4">Update Password</button>
                </div>
            </form>
        </div>

    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
