<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Smart Library System</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link href="/styles/style.css" rel="stylesheet">
</head>
<body>

<%- include("partials/header.ejs") %>


<div class="container-fluid mt-4">
    <div class="row">

        <!-- ADVANCED FILTER -->
        <div class="col-md-3">
            <div class="bg-primary text-white text-center p-2">
                <h3 class="fw-bold">
                    Advanced Filtering
                </h3>
            </div>
            <div class="border p-4">
                <h5>Categories</h5>
                <ul class="list-unstyled">
                    <li>
                        <input class="form-check-input"
                               type="checkbox"
                               name="genre"
                               id="fantasy"
                               value="Fantasy">

                        <label class="form-check-label" for="fantasy">
                            Fantasy
                        </label>
                    </li>

                    <li>
                        <input class="form-check-input"
                               type="checkbox"
                               name="genre"
                               id="Sci-fi"
                               value="ScienceFiction">

                        <label class="form-check-label" for="Sci-fi">
                            Science Fiction
                        </label>
                    </li>


                    <li>
                        <input class="form-check-input"
                               type="checkbox"
                               name="genre"
                               id="romance"
                               value="Romance">

                        <label class="form-check-label" for="romance">
                            Romance
                        </label>
                    </li>

                    <li>
                        <input class="form-check-input"
                               type="checkbox"
                               name="genre"
                               id="mystery-crime"
                               value="Mystery-Crime">

                        <label class="form-check-label" for="mystery-crime">
                            Mystery Crime
                        </label>
                    </li>

                    <li>
                        <input class="form-check-input"
                               type="checkbox"
                               name="genre"
                               id="thriller"
                               value="Thriller">

                        <label class="form-check-label" for="thriller">
                            Thriller/Suspense
                        </label>
                    </li>

                    <li>
                        <input class="form-check-input"
                               type="checkbox"
                               name="genre"
                               id="horror"
                               value="Horror">

                        <label class="form-check-label" for="horror">
                            Horror
                        </label>
                    </li>

                    <li>
                        <input class="form-check-input"
                               type="checkbox"
                               name="genre"
                               id="historical"
                               value="historical">

                        <label class="form-check-label" for="historical">
                            Historical
                        </label>
                    </li>

                    <li>
                        <input class="form-check-input"
                               type="checkbox"
                               name="genre"
                               id="fiction"
                               value="Fiction">

                        <label class="form-check-label" for="fiction">
                            Fiction
                        </label>
                    </li>


                    <li>
                        <input class="form-check-input"
                               type="checkbox"
                               name="genre"
                               id="biography"
                               value="Biography">

                        <label class="form-check-label" for="biography">
                            Memoir/Biography
                        </label>
                    </li>

                    <li>
                        <input class="form-check-input"
                               type="checkbox"
                               name="genre"
                               id="self-help"
                               value="Self-Help">

                        <label class="form-check-label" for="self-help">
                            Self Help
                        </label>
                    </li>

                    <li>
                        <input class="form-check-input"
                               type="checkbox"
                               name="genre"
                               id="business"
                               value="Business">

                        <label class="form-check-label" for="business">
                            Business
                        </label>
                    </li>
                </ul>

            </div>
        </div>

        <!-- BOOK DISPLAY -->
        <div class="col-md-9">
            <div class="border p-4">
                <div class="row g-4">


                    <div class="col-md-4">
                        <div class="border">
                            <div style="height: 220px;"></div>
                            <div class="bg-secondary"
                                 style="height: 80px;">
                            </div>
                        </div>
                    </div>


                    <div class="col-md-4">
                        <div class="border">
                            <div style="height: 220px;"></div>
                            <div class="bg-secondary"
                                 style="height: 80px;">
                            </div>
                        </div>
                    </div>


                    <div class="col-md-4">
                        <div class="border">
                            <div style="height: 220px;"></div>
                            <div class="bg-secondary"
                                 style="height: 80px;">
                            </div>
                        </div>
                    </div>


                    <div class="col-md-4">
                        <div class="border">
                            <div style="height: 220px;"></div>
                            <div class="bg-secondary"
                                 style="height: 80px;">
                            </div>
                        </div>
                    </div>


                    <div class="col-md-4">
                        <div class="border">
                            <div style="height: 220px;"></div>
                            <div class="bg-secondary"
                                 style="height: 80px;">
                            </div>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="border">
                            <div style="height: 220px;"></div>
                            <div class="bg-secondary"
                                 style="height: 80px;">
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>


<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
        crossorigin="anonymous">
</script>
</body>
</html>