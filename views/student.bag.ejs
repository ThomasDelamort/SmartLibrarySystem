<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>My Bag - Smart Library</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/styles/style.css">
    <link rel="stylesheet" href="/styles/layout.css">
</head>

<body>

<%- include("partials/header.ejs") %>

<div class="container-fluid mt-4">
    <div class="container">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold mb-0">🛒 My Bag</h2>
            <span class="badge bg-dark fs-6"><%= items.length %> Item<%= items.length !== 1 ? 's' : '' %></span>
        </div>

        <% if (items.length === 0) { %>
        <div class="text-center mt-5">
            <p class="text-muted fs-5">Your bag is empty.</p>
            <a href="/Students" class="btn btn-outline-dark mt-2">Browse Books</a>
        </div>
        <% } else { %>

        <div class="d-flex flex-column gap-3 mb-4">
            <% items.forEach(item => { %>
            <div class="card border-0 shadow-sm p-3">
                <div class="row align-items-center">

                    <div class="col-md-1 text-center">
                        <img src="<%= item.book.image %>"
                             alt="<%= item.book.title %>"
                             class="img-fluid rounded"
                             style="max-height: 120px; object-fit: cover;">
                    </div>

                    <div class="col-md-6">
                        <h5 class="fw-bold mb-1"><%= item.book.title %></h5>
                        <p class="text-muted mb-1"><%= item.book.author.join(", ") %></p>
                        <small class="text-muted">
                            Due: <strong><%= new Date(item.dueDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></strong>
                        </small>
                    </div>

                    <div class="col-md-2">
                        <span class="badge <%= item.book.status === 'available' ? 'bg-success' : 'bg-secondary' %> fs-6">
                            <%= item.book.status.charAt(0).toUpperCase() + item.book.status.slice(1) %>
                        </span>
                    </div>

                    <div class="col-md-3">
                        <form action="/Students/Bag/Remove/<%= item.book._id %>" method="POST">
                            <button type="submit" class="btn btn-outline-danger w-100">
                                Remove
                            </button>
                        </form>
                    </div>

                </div>
            </div>
            <% }) %>
        </div>

        <div class="d-flex justify-content-end gap-3">
            <a href="/Students" class="btn btn-outline-secondary btn-lg">Continue Browsing</a>
            <form action="/Students/Bag/BorrowAll" method="POST">
                <button type="submit" class="btn btn-primary btn-lg">
                    Borrow All (<%= items.length %>)
                </button>
            </form>
        </div>

        <% } %>

    </div>
</div>


<div style="margin-top: 50vh;">
    <section class="card-footer">
        <footer>

            <ul class="social_icon col-md">
                <li><a href="#"><ion-icon name="logo-facebook"></ion-icon></a></li>
                <li><a href="#"><ion-icon name="logo-discord"></ion-icon></a></li>
                <li><a href="#"><ion-icon name="logo-linkedin"></ion-icon></a></li>
                <li><a href="#"><ion-icon name="logo-instagram"></ion-icon></a></li>
                <li><a href="#"><ion-icon name="logo-github"></ion-icon></a></li>
            </ul>

            <ul class="menu">
                <li><a href="/">Home</a></li>
                <li><a href="/About">About</a></li>
                <li><a href="/Contact">Services</a></li>
                <li><a href="#">Team</a></li>
                <li><a href="/Contact">Contact</a></li>
            </ul>

            <p class="copyright">
                © <%= new Date().getFullYear() %> SmartLibSys 📚
            </p>

        </footer>
    </section>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
<script type="module" src="https://unpkg.com/ionicons@5.5.2/dist/ionicons/ionicons.esm.js"></script>
<script nomodule src="https://unpkg.com/ionicons@5.5.2/dist/ionicons/ionicons.js"></script>
</body>
</html>
