<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SmartLib Admin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/dist/tabler-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/styles/admin.css">
    <style>
        /* Give every section a scroll-margin so the sticky topbar doesn't overlap */
        section[id] {
            scroll-margin-top: 56px; /* match your topbar height */
        }
    </style>
</head>
<body>

<div class="shell">

    <%- include("partials/admin.sidebar.ejs") %>

    <div class="main">
        <div class="topbar">
            <div class="page-title" id="active-section-title">Dashboard</div>
            <div class="topbar-right">
                <div class="bell-btn"><i class="ti ti-bell" style="font-size:16px"></i></div>
                <button class="gen-btn" onclick="generateMonthlyReport()"><i class="ti ti-file-export"></i> Generate Report</button>
            </div>
        </div>

        <div class="content">
            <!-- Dashboard -->
            <section id="dashboard">
                <%- include("partials/admin.dashboard.ejs") %>
            </section>

            <!-- Students -->
            <section id="students">
                <%- include("partials/admin.students.ejs") %>
            </section>

            <!-- Librarians -->
            <section id="librarians">
                <%- include("partials/admin.librarians.ejs") %>
            </section>

            <!-- Books -->
            <section id="books">
                <%- include("partials/admin.books.ejs") %>
            </section>

            <!-- Rooms -->
            <section id="rooms">
                <%- include("partials/admin.rooms.ejs") %>
            </section>

            <!-- Transactions -->
            <section id="transactions">
                <%- include("partials/admin.transactions.ejs") %>
            </section>
        </div>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<script src="/js/admin.dashboard.js"></script>
<script>
    const sections = ['dashboard', 'students', 'librarians', 'books', 'rooms', 'transactions'];
    const navItems = document.querySelectorAll('.nav-item[data-section]');
    const titleEl = document.getElementById('active-section-title');

    const titles = {
        dashboard: 'Dashboard',
        students: 'Students',
        librarians: 'Librarians',
        books: 'Books',
        rooms: 'Rooms',
        transactions: 'Transactions'
    };

    // Highlight active nav on scroll
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                const id = entry.target.id;
                navItems.forEach(item => {
                    item.classList.toggle('active', item.dataset.section === id);
                });
                titleEl.textContent = titles[id] || 'Dashboard';
            }
        });
    }, { threshold: 0.3 });

    sections.forEach(id => {
        const el = document.getElementById(id);
        if (el) observer.observe(el);
    });

    // Smooth scroll on nav click
    navItems.forEach(item => {
        item.addEventListener('click', (e) => {
            e.preventDefault();
            const target = document.getElementById(item.dataset.section);
            if (target) target.scrollIntoView({ behavior: 'smooth' });
        });
    });
</script>
<script>
    function generateMonthlyReport() {
        const now = new Date();
        const year = now.getFullYear();
        const month = now.getMonth() + 1;
        window.location.href = `/Admin/Report/Monthly?year=${year}&month=${month}`;
    }
</script>
</body>
</html>