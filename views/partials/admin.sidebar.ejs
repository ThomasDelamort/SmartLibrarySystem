<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Sidebar for admin</title>
</head>
<body>

<div class="sidebar">
    <div class="logo">
        <div class="logo-icon"><i class="ti ti-shield" style="color:#0f172a;font-size:15px"></i></div>
        SmartLibSys
    </div>
    <nav>
        <a class="nav-item active" data-section="dashboard"><i class="ti ti-layout-dashboard"></i>Dashboard</a>
        <a class="nav-item" data-section="students"><i class="ti ti-users"></i>Students</a>
        <a class="nav-item" data-section="librarians"><i class="ti ti-user-check"></i>Librarians</a>
        <a class="nav-item" data-section="books"><i class="ti ti-book"></i>Books</a>
        <a class="nav-item" data-section="rooms"><i class="ti ti-building"></i>Rooms</a>
        <a class="nav-item" data-section="transactions"><i class="ti ti-arrow-left-right"></i>Transactions</a>
    </nav>
    <div class="sidebar-bottom">
        <div class="user-info">
            <div class="uavatar"><i class="ti ti-user"></i></div>
            <div>
                <div class="user-name"><%= user?.name %> <%= user?.lastName %></div>
                <div class="user-role">Administrator</div>
            </div>
        </div>
        <a href="/LogOut" class="logout-btn"><i class="ti ti-logout"></i> Logout</a>
    </div>
</div>

</body>
</html>