<div class="sec-divider"></div>
<div class="sec">
    <div class="sec-label">Rooms</div>


    <div class="panel mb-10">
        <div class="panel-hdr">
            <div class="panel-title"><i class="ti ti-plus"></i>Add Room</div>
        </div>
        <form action="/Admin/Rooms/Add" method="POST" style="display:grid;grid-template-columns:1fr 1fr 1fr auto;gap:10px;align-items:end;">
            <div>
                <label style="font-size:11px;color:var(--text-muted);display:block;margin-bottom:4px;">Room Number</label>
                <input type="text" name="number" placeholder="e.g. 101" required
                       style="width:100%;font-size:12px;padding:7px 10px;border:1px solid var(--border);border-radius:8px;background:#f8fafc;color:var(--text-primary);">
            </div>
            <div>
                <label style="font-size:11px;color:var(--text-muted);display:block;margin-bottom:4px;">Capacity</label>
                <input type="number" name="capacity" placeholder="e.g. 10" min="1" required
                       style="width:100%;font-size:12px;padding:7px 10px;border:1px solid var(--border);border-radius:8px;background:#f8fafc;color:var(--text-primary);">
            </div>
            <div>
                <label style="font-size:11px;color:var(--text-muted);display:block;margin-bottom:4px;">Description</label>
                <input type="text" name="description" placeholder="Optional"
                       style="width:100%;font-size:12px;padding:7px 10px;border:1px solid var(--border);border-radius:8px;background:#f8fafc;color:var(--text-primary);">
            </div>
            <button type="submit"
                    style="background:#0f172a;color:white;border:none;border-radius:8px;padding:7px 14px;font-size:12px;cursor:pointer;white-space:nowrap;">
                <i class="ti ti-plus"></i> Add Room
            </button>
        </form>
    </div>

    <!-- Rooms Table -->
    <div class="panel">
        <div class="panel-hdr">
            <div class="panel-title"><i class="ti ti-building"></i>All Rooms</div>
            <span style="font-size:11px;color:var(--text-muted)"><%= rooms.length %> total</span>
        </div>

        <% if (rooms.length === 0) { %>
        <p style="font-size:12px;color:var(--text-muted)">No rooms found.</p>
        <% } %>

        <div style="overflow-x:auto;">
            <table style="width:100%;border-collapse:collapse;font-size:12px;">
                <thead>
                <tr style="background:#f8fafc;">
                    <th style="padding:10px 12px;text-align:left;color:var(--text-secondary);font-weight:600;border-bottom:1px solid var(--border);">Room</th>
                    <th style="padding:10px 12px;text-align:left;color:var(--text-secondary);font-weight:600;border-bottom:1px solid var(--border);">Capacity</th>
                    <th style="padding:10px 12px;text-align:left;color:var(--text-secondary);font-weight:600;border-bottom:1px solid var(--border);">Description</th>
                    <th style="padding:10px 12px;text-align:left;color:var(--text-secondary);font-weight:600;border-bottom:1px solid var(--border);">Status</th>
                    <th style="padding:10px 12px;text-align:left;color:var(--text-secondary);font-weight:600;border-bottom:1px solid var(--border);">Actions</th>
                </tr>
                </thead>
                <tbody>
                <% rooms.forEach(function(room) { %>
                <tr style="border-bottom:1px solid var(--border);">
                    <td style="padding:10px 12px;">
                        <div class="acct-name">Room <%= room.number %></div>
                    </td>
                    <td style="padding:10px 12px;color:var(--text-secondary);"><%= room.capacity %> pax</td>
                    <td style="padding:10px 12px;color:var(--text-secondary);">
                        <%= room.description || '—' %>
                    </td>
                    <td style="padding:10px 12px;">
                        <span class="badge <%=
                            room.status === 'available' ? 'badge-green' :
                            room.status === 'reserved'  ? 'badge-warn' :
                            'badge-red'
                        %>"><%= room.status %></span>
                    </td>
                    <td style="padding:10px 12px;">
                        <div style="display:flex;gap:6px;">
                            <form action="/Admin/Rooms/Status/<%= room._id %>" method="POST" style="display:flex;gap:4px;">
                                <select name="status"
                                        style="font-size:11px;padding:4px 6px;border:1px solid var(--border);border-radius:6px;background:white;color:var(--text-primary);">
                                    <option value="available"> <%= room.status === 'available' ? 'selected' : '' %>>Available</option>
                                    <option value="reserved">  <%= room.status === 'reserved'  ? 'selected' : '' %>>Reserved</option>
                                    <option value="maintenance"> <%= room.status === 'maintenance' ? 'selected' : '' %>>Maintenance</option>
                                </select>
                                <button type="submit"
                                        style="font-size:11px;padding:5px 10px;border-radius:6px;border:1px solid var(--border);background:white;cursor:pointer;color:var(--text-primary);">
                                    Update
                                </button>
                            </form>
                            <form action="/Admin/Rooms/Delete/<%= room._id %>" method="POST"
                                  onsubmit="return confirm('Delete this room?')">
                                <button type="submit"
                                        style="font-size:11px;padding:5px 10px;border-radius:6px;border:1px solid #fecdd3;background:#fff1f2;color:#e11d48;cursor:pointer;">
                                    Delete
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
                <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>
