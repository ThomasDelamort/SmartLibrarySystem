<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Librarian Books</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/styles/layout.css">
    <link rel="stylesheet" href="/styles/librarian.css">
    <link rel="stylesheet" href="/styles/librarian.book.css">

</head>
<body>

<%- include("partials/librarian.header.ejs") %>

<div class="container-fluid mt-4">
    <div class="container books-container">
        <div class="books-header">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
                <div>
                    <h2 class="fw-bold mb-1">
                        Books
                    </h2>
                </div>
                <button class="btn btn-dark btn-lg rounded-4 px-4">
                    Add New Book
                </button>
            </div>
        </div>
        <div class="books-list">
            <div class="d-flex flex-column gap-3">
                <div class="book-item">
                    <div class="row align-items-center">
                        <div class="col-md-2 text-center">
                            <img src="https://m.media-amazon.com/images/I/81wgcld4wxL.jpg"
                                 alt="book"
                                 class="book-cover">
                        </div>
                        <div class="col-md-7">
                            <div class="title-status">
                                <h5 class="book-title">
                                    Atomic Habits
                                </h5><span class="status-borrowed">Borrowed</span>
                            </div>

                            <p class="book-meta">
                                <strong>Author:</strong>
                                James Clear
                            </p>
                            <p class="book-meta">
                                <strong>Description:</strong>
                                A practical guide to building good habits and breaking bad ones.
                            </p>
                            <span class="book-category">
                            Self Help
                        </span>

                        </div>
                        <div class="col-md-3">
                            <div class="book-actions d-flex flex-column gap-2">
                                <button class="btn btn-outline-dark">
                                    View
                                </button>
                                <button class="btn btn-outline-primary">
                                    Edit
                                </button>
                                <button class="btn btn-outline-danger">
                                    Delete
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="book-item">
                    <div class="row align-items-center">
                        <div class="col-md-2 text-center">
                            <img src="https://m.media-amazon.com/images/I/91bYsX41DVL.jpg"
                                 alt="book"
                                 class="book-cover">
                        </div>
                        <div class="col-md-7">
                            <div class="title-status">
                                <h5 class="book-title">
                                    Harry Potter
                                </h5><span class="status-available">Available</span>
                            </div>
                            <p class="book-meta">
                                <strong>Author:</strong>
                                J.K. Rowling
                            </p>
                            <p class="book-meta">
                                <strong>Description:</strong>
                                A young wizard discovers his magical destiny at Hogwarts.
                            </p>
                            <span class="book-category">
                            Fantasy
                        </span>
                        </div>

                        <div class="col-md-3">
                            <div class="book-actions d-flex flex-column gap-2">
                                <button class="btn btn-outline-dark">
                                    View
                                </button>
                                <button class="btn btn-outline-primary">
                                    Edit
                                </button>
                                <button class="btn btn-outline-danger">
                                    Delete
                                </button>
                            </div>
                        </div>
                    </div>
                </div>


                <div class="book-item">
                    <div class="row align-items-center">
                        <div class="col-md-2 text-center">
                            <img src="https://m.media-amazon.com/images/I/71UwSHSZRnS.jpg"
                                 alt="book"
                                 class="book-cover">
                        </div>
                        <div class="col-md-7">
                            <h5 class="book-title">
                                Rich Dad Poor Dad
                            </h5>
                            <p class="book-meta">
                                <strong>Author:</strong>
                                Robert Kiyosaki
                            </p>
                            <p class="book-meta">
                                <strong>Description:</strong>
                                Learn financial literacy and investing strategies.
                            </p>
                            <span class="book-category">
                            Business
                        </span>
                        </div>

                        <div class="col-md-3">
                            <div class="book-actions d-flex flex-column gap-2">
                                <button class="btn btn-outline-dark">
                                    View
                                </button>
                                <button class="btn btn-outline-primary">
                                    Edit
                                </button>
                                <button class="btn btn-outline-danger">
                                    Delete
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="d-flex justify-content-center mt-5">
                <nav>
                    <ul class="pagination">
                        <li class="page-item disabled">
                            <a class="page-link" href="#">
                                Previous
                            </a>
                        </li>
                        <li class="page-item active">
                            <a class="page-link" href="#">
                                1
                            </a>
                        </li>
                        <li class="page-item">
                            <a class="page-link" href="#">
                                2
                            </a>
                        </li>
                        <li class="page-item">
                            <a class="page-link" href="#">
                                3
                            </a>
                        </li>
                        <li class="page-item">
                            <a class="page-link" href="#">
                                Next
                            </a>
                        </li>
                    </ul>
                </nav>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>