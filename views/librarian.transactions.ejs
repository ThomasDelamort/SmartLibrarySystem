<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Transactions Dashboard</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/styles/layout.css">
    <link rel="stylesheet" href="/styles/librarian.css">
    <link rel="stylesheet" href="/styles/librarian.transactions.css">
</head>

<body>

<%- include("partials/librarian.header.ejs") %>

<div class="container-fluid mt-4">
    <div class="transactions-container">

        <div class="transactions-header">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
                <div>
                    <h2 class="fw-bold mb-1">Transactions</h2>
                </div>
                <button class="btn btn-dark btn-lg rounded-4 px-4">Export Report</button>
            </div>
        </div>

        <!-- Stats -->
        <div class="row g-4 mb-4">
            <div class="col-md-4">
                <div class="stats-card">
                    <h6 class="stats-title">Borrowed Books</h6>
                    <h2 class="stats-value"><%= stats.borrowed %></h2>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stats-card">
                    <h6 class="stats-title">Returned Today</h6>
                    <h2 class="stats-value"><%= stats.returnedToday %></h2>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stats-card overdue-card">
                    <h6 class="stats-title">Overdue Books</h6>
                    <h2 class="stats-value"><%= stats.overdue %></h2>
                </div>
            </div>
        </div>

        <!-- Book Transactions -->
        <h5 class="fw-bold mb-3">Book Transactions</h5>
        <div class="transactions-list mb-5">
            <div class="d-flex flex-column gap-3">

                <% if (bookTransactions.length === 0) { %>
                <p class="text-muted">No pending book transactions.</p>
                <% } %>

                <% bookTransactions.forEach(txn => { %>
                <div class="transaction-item">
                    <div class="row align-items-center">

                        <div class="col-md-1 text-center">
                            <img src="https://cdn.pixabay.com/photo/2015/10/05/22/37/blank-profile-picture-973460_1280.png"
                                 alt="student"
                                 class="transaction-image">
                        </div>

                        <div class="col-md-5">
                            <h5 class="transaction-name">
                                <%= txn.student ? `${txn.student.firstName} ${txn.student.lastName}` : 'Unknown Student' %>
                            </h5>
                            <p class="transaction-book">
                                <%= txn.transactionType === 'return' ? 'Requesting to return' : 'Requesting to borrow' %>:
                                <strong><%= txn.book.title %></strong>
                            </p>
                            <span class="transaction-date">
                                    Due: <%= new Date(txn.dueDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %>
                                </span>
                        </div>

                        <div class="col-md-3">
                                <span class="<%= txn.transactionType === 'return' ? 'status-returned' : 'status-borrowed' %>">
                                    <%= txn.transactionType === 'return' ? 'Return Request' : 'Borrow Request' %>
                                </span>
                        </div>

                        <div class="col-md-3">
                            <div class="transaction-actions d-flex flex-column gap-2">
                                <% if (txn.transactionType === 'return') { %>
                                <form action="/Librarian-Transactions/Return/<%= txn._id %>" method="POST">
                                    <button type="submit" class="btn btn-outline-success w-100">Confirm Return</button>
                                </form>
                                <% } else { %>
                                <form action="/Librarian-Transactions/Approve/<%= txn._id %>" method="POST">
                                    <button type="submit" class="btn btn-outline-success w-100">Approve</button>
                                </form>
                                <% } %>
                                <form action="/Librarian-Transactions/Reject/<%= txn._id %>" method="POST">
                                    <button type="submit" class="btn btn-outline-danger w-100">Reject</button>
                                </form>
                            </div>
                        </div>

                    </div>
                </div>
                <% }) %>

            </div>
        </div>

        <!-- Room Transactions -->
        <h5 class="fw-bold mb-3">Room Reservations</h5>
        <div class="transactions-list">
            <div class="d-flex flex-column gap-3">

                <% if (roomTransactions.length === 0) { %>
                <p class="text-muted">No pending room reservations.</p>
                <% } %>

                <% roomTransactions.forEach(txn => { %>
                <div class="transaction-item">
                    <div class="row align-items-center">

                        <div class="col-md-1 text-center">
                            <img src="https://cdn.pixabay.com/photo/2015/10/05/22/37/blank-profile-picture-973460_1280.png"
                                 alt="student"
                                 class="transaction-image">
                        </div>

                        <div class="col-md-5">
                            <h5 class="transaction-name">
                                <%= txn.reservee ? `${txn.reservee.firstName} ${txn.reservee.lastName}` : 'Unknown Student' %>
                            </h5>
                            <p class="transaction-book">
                                Requesting to reserve: <strong>Room <%= txn.room.number %></strong>
                            </p>
                            <span class="transaction-date">
                                    <%= new Date(txn.reservationDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %>
                                    &nbsp;|&nbsp;
                                    <%= txn.startTime %> - <%= txn.endTime %>
                                </span>
                            <% if (txn.purpose) { %>
                            <br><small class="text-muted">Purpose: <%= txn.purpose %></small>
                            <% } %>
                        </div>

                        <div class="col-md-3">
                            <span class="status-borrowed">Room Request</span>
                        </div>

                        <div class="col-md-3">
                            <div class="transaction-actions d-flex flex-column gap-2">
                                <form action="/Librarian-Transactions/Room/Approve/<%= txn._id %>" method="POST">
                                    <button type="submit" class="btn btn-outline-success w-100">Approve</button>
                                </form>
                                <form action="/Librarian-Transactions/Room/Reject/<%= txn._id %>" method="POST">
                                    <button type="submit" class="btn btn-outline-danger w-100">Reject</button>
                                </form>
                            </div>
                        </div>

                    </div>
                </div>
                <% }) %>

            </div>
        </div>

    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>