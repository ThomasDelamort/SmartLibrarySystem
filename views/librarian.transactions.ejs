<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Transactions Dashboard</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/styles/layout.css">
    <link rel="stylesheet" href="/styles/librarian.css">
    <link rel="stylesheet" href="/styles/librarian.transactions.css">
</head>

<body>

<%- include("partials/librarian.header.ejs") %>

<div class="container-fluid mt-4">
    <div class="transactions-container">

        <div class="transactions-header">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
                <div>
                    <h2 class="fw-bold mb-1">Transactions</h2>
                </div>
                <button class="btn btn-dark btn-lg rounded-4 px-4"
                        data-bs-toggle="modal"
                        data-bs-target="#manualTransactionModal">
                    + Create Transaction
                </button>
            </div>
        </div>

        <!-- Stats -->
        <div class="row g-4 mb-4">
            <div class="col-md-4">
                <div class="stats-card">
                    <h6 class="stats-title">Borrowed Books</h6>
                    <h2 class="stats-value"><%= stats.borrowed %></h2>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stats-card">
                    <h6 class="stats-title">Returned Today</h6>
                    <h2 class="stats-value"><%= stats.returnedToday %></h2>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stats-card overdue-card">
                    <h6 class="stats-title">Overdue Books</h6>
                    <h2 class="stats-value"><%= stats.overdue %></h2>
                </div>
            </div>
        </div>

        <!-- Book Transactions -->
        <h5 class="fw-bold mb-3">Book Transactions</h5>
        <div class="transactions-list mb-5">
            <div class="d-flex flex-column gap-3">

                <% if (bookTransactions.length === 0) { %>
                <p class="text-muted">No pending book transactions.</p>
                <% } %>

                <% bookTransactions.forEach(txn => { %>
                <div class="transaction-item">
                    <div class="row align-items-center">

                        <div class="col-md-1 text-center">
                            <img src="https://cdn.pixabay.com/photo/2015/10/05/22/37/blank-profile-picture-973460_1280.png"
                                 alt="student" class="transaction-image">
                        </div>

                        <div class="col-md-5">
                            <h5 class="transaction-name">
                                <%= txn.student ? `${txn.student.firstName} ${txn.student.lastName}` : 'Unknown Student' %>
                            </h5>
                            <p class="transaction-book">
                                <%= txn.transactionType === 'return' ? 'Requesting to return' : 'Requesting to borrow' %>:
                                <strong><%= txn.book.title %></strong>
                            </p>
                            <span class="transaction-date">
                                Due: <%= new Date(txn.dueDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %>
                            </span>
                        </div>

                        <div class="col-md-3">
                            <span class="<%= txn.transactionType === 'return' ? 'status-returned' : 'status-borrowed' %>">
                                <%= txn.transactionType === 'return' ? 'Return Request' : 'Borrow Request' %>
                            </span>
                        </div>

                        <div class="col-md-3">
                            <div class="transaction-actions d-flex flex-column gap-2">
                                <% if (txn.transactionType === 'return') { %>
                                <form action="/Librarian-Transactions/Return/<%= txn._id %>" method="POST">
                                    <button type="submit" class="btn btn-outline-success w-100">Confirm Return</button>
                                </form>
                                <% } else { %>
                                <form action="/Librarian-Transactions/Approve/<%= txn._id %>" method="POST">
                                    <button type="submit" class="btn btn-outline-success w-100">Approve</button>
                                </form>
                                <% } %>
                                <form action="/Librarian-Transactions/Reject/<%= txn._id %>" method="POST">
                                    <button type="submit" class="btn btn-outline-danger w-100">Reject</button>
                                </form>
                            </div>
                        </div>

                    </div>
                </div>
                <% }) %>

            </div>
        </div>

        <!-- Room Transactions -->
        <h5 class="fw-bold mb-3">Room Reservations</h5>
        <div class="transactions-list">
            <div class="d-flex flex-column gap-3">

                <% if (roomTransactions.length === 0) { %>
                <p class="text-muted">No pending room reservations.</p>
                <% } %>

                <% roomTransactions.forEach(txn => { %>
                <div class="transaction-item">
                    <div class="row align-items-center">

                        <div class="col-md-1 text-center">
                            <img src="https://cdn.pixabay.com/photo/2015/10/05/22/37/blank-profile-picture-973460_1280.png"
                                 alt="student" class="transaction-image">
                        </div>

                        <div class="col-md-5">
                            <h5 class="transaction-name">
                                <%= txn.reservee ? `${txn.reservee.firstName} ${txn.reservee.lastName}` : 'Unknown Student' %>
                            </h5>
                            <p class="transaction-book">
                                Requesting to reserve: <strong>Room <%= txn.room.number %></strong>
                            </p>
                            <span class="transaction-date">
                                <%= new Date(txn.reservationDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %>
                                &nbsp;|&nbsp;
                                <%= txn.startTime %> - <%= txn.endTime %>
                            </span>
                            <% if (txn.purpose) { %>
                            <br><small class="text-muted">Purpose: <%= txn.purpose %></small>
                            <% } %>
                        </div>

                        <div class="col-md-3">
                            <span class="status-borrowed">Room Request</span>
                        </div>

                        <div class="col-md-3">
                            <div class="transaction-actions d-flex flex-column gap-2">
                                <form action="/Librarian-Transactions/Room/Approve/<%= txn._id %>" method="POST">
                                    <button type="submit" class="btn btn-outline-success w-100">Approve</button>
                                </form>
                                <form action="/Librarian-Transactions/Room/Reject/<%= txn._id %>" method="POST">
                                    <button type="submit" class="btn btn-outline-danger w-100">Reject</button>
                                </form>
                            </div>
                        </div>

                    </div>
                </div>
                <% }) %>

            </div>
        </div>

    </div>
</div>

<!-- Manual Transaction Modal -->
<div class="modal fade" id="manualTransactionModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title fw-bold">Create Manual Transaction</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <form action="/Librarian-Transactions/Manual" method="POST" id="manualTransactionForm">
                <div class="modal-body">

                    <!-- Transaction Type -->
                    <div class="mb-4">
                        <label class="form-label fw-semibold">Transaction Type</label>
                        <div class="d-flex gap-2 flex-wrap">
                            <input type="radio" class="btn-check" name="type" id="typeBorrow" value="borrow" checked>
                            <label class="btn btn-outline-primary" for="typeBorrow">📖 Borrow</label>

                            <input type="radio" class="btn-check" name="type" id="typeReturn" value="return">
                            <label class="btn btn-outline-success" for="typeReturn">↩️ Return</label>

                            <input type="radio" class="btn-check" name="type" id="typeRoom" value="room">
                            <label class="btn btn-outline-warning" for="typeRoom">🚪 Room Reserve</label>

                            <input type="radio" class="btn-check" name="type" id="typeSettle" value="settle">
                            <label class="btn btn-outline-danger" for="typeSettle">💰 Settle Fines</label>
                        </div>
                    </div>

                    <!-- Student Search -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Student</label>
                        <div class="input-group mb-2">
                            <input type="text" id="studentSearchInput" class="form-control"
                                   placeholder="Search by name, email, or ID...">
                            <button type="button" class="btn btn-outline-dark" onclick="searchStudentModal()">Search</button>
                        </div>
                        <div id="studentSearchResults" class="d-flex flex-column gap-1 mb-2"></div>
                        <div id="selectedStudentDisplay" style="display:none;"
                             class="d-flex justify-content-between align-items-center p-2 bg-light rounded">
                            <div>
                                <small class="fw-semibold" id="selectedStudentName"></small>
                                <small class="text-muted d-block" id="selectedStudentEmail"></small>
                            </div>
                            <button type="button" class="btn btn-sm btn-outline-danger" onclick="clearStudent()">Remove</button>
                        </div>
                        <input type="hidden" name="studentId" id="studentIdInput">
                    </div>

                    <!-- Borrow Fields -->
                    <div id="borrowFields">
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Book</label>
                            <select name="bookId" class="form-select">
                                <option value="" disabled selected>Select a book</option>
                                <% books.forEach(function(b) { %>
                                <option value="<%= b._id %>"><%= b.title %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Due Date</label>
                            <input type="date" name="dueDate" class="form-control">
                        </div>
                    </div>

                    <!-- Return Fields -->
                    <div id="returnFields" style="display:none;">
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Book to Return</label>
                            <select name="bookId" class="form-select">
                                <option value="" disabled selected>Select a book</option>
                                <% books.forEach(function(b) { %>
                                <option value="<%= b._id %>"><%= b.title %></option>
                                <% }) %>
                            </select>
                            <small class="text-muted">Note: Only books currently borrowed by the selected student will process correctly.</small>
                        </div>
                    </div>

                    <!-- Room Fields -->
                    <div id="roomFields" style="display:none;">
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Room</label>
                            <select name="roomId" class="form-select">
                                <option value="" disabled selected>Select a room</option>
                                <% rooms.forEach(function(r) { %>
                                <option value="<%= r._id %>">Room <%= r.number %> (Capacity: <%= r.capacity %>)</option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Reservation Date</label>
                            <input type="date" name="reservationDate" class="form-control">
                        </div>
                        <div class="row g-3 mb-3">
                            <div class="col">
                                <label class="form-label fw-semibold">Start Time</label>
                                <input type="time" name="startTime" class="form-control">
                            </div>
                            <div class="col">
                                <label class="form-label fw-semibold">End Time</label>
                                <input type="time" name="endTime" class="form-control">
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Purpose <span class="text-muted fw-normal">(optional)</span></label>
                            <input type="text" name="purpose" class="form-control" placeholder="e.g. Group study, Meeting">
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Number of Attendees</label>
                            <input type="number" name="attendeesCount" class="form-control" min="1" value="1">
                        </div>
                    </div>

                    <!-- Settle Fines Fields -->
                    <div id="settleFields" style="display:none;">
                        <div class="mb-3">
                            <p class="text-muted">This will clear the selected student's unpaid fines and restore borrowing privileges if suspended.</p>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Student's Current Fines</label>
                            <div id="studentFinesDisplay" class="form-control bg-light text-muted">
                                Select a student to see their fines
                            </div>
                        </div>
                    </div>

                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-dark px-4">Create Transaction</button>
                </div>
            </form>

        </div>
    </div>
</div>

<script>
    const typeInputs = document.querySelectorAll('input[name="type"]');
    const borrowFields = document.getElementById('borrowFields');
    const returnFields = document.getElementById('returnFields');
    const roomFields = document.getElementById('roomFields');
    const settleFields = document.getElementById('settleFields');
    const finesDisplay = document.getElementById('studentFinesDisplay');

    typeInputs.forEach(input => {
        input.addEventListener('change', () => {
            borrowFields.style.display = input.value === 'borrow' ? 'block' : 'none';
            returnFields.style.display = input.value === 'return' ? 'block' : 'none';
            roomFields.style.display   = input.value === 'room'   ? 'block' : 'none';
            settleFields.style.display = input.value === 'settle' ? 'block' : 'none';
        });
    });

    async function searchStudentModal() {
        const query = document.getElementById('studentSearchInput').value.trim();
        if (!query) return;

        const res = await fetch(`/Students/Search?q=${encodeURIComponent(query)}`);
        const students = await res.json();

        const resultsDiv = document.getElementById('studentSearchResults');
        resultsDiv.innerHTML = '';

        if (students.length === 0) {
            resultsDiv.innerHTML = '<small class="text-muted">No students found.</small>';
            return;
        }

        students.forEach(s => {
            const el = document.createElement('div');
            el.className = 'd-flex justify-content-between align-items-center p-2 border rounded';
            el.innerHTML = `
                <div>
                    <small class="fw-semibold">${s.firstName} ${s.lastName}</small>
                    <small class="text-muted d-block">${s.email} — ${s.studentId}</small>
                </div>
                <button type="button" class="btn btn-sm btn-outline-dark"
                        onclick="selectStudent('${s._id}', '${s.firstName} ${s.lastName}', '${s.email}', ${s.fines || 0})">
                    Select
                </button>
            `;
            resultsDiv.appendChild(el);
        });
    }

    function selectStudent(id, name, email, fines) {
        document.getElementById('studentIdInput').value = id;
        document.getElementById('selectedStudentName').textContent = name;
        document.getElementById('selectedStudentEmail').textContent = email;
        document.getElementById('selectedStudentDisplay').style.display = 'flex';
        document.getElementById('studentSearchResults').innerHTML = '';
        document.getElementById('studentSearchInput').value = '';

        if (finesDisplay) {
            finesDisplay.textContent = fines > 0 ? `$${fines} unpaid` : 'No unpaid fines';
            finesDisplay.className = `form-control bg-light fw-bold ${fines > 0 ? 'text-danger' : 'text-success'}`;
        }
    }

    function clearStudent() {
        document.getElementById('studentIdInput').value = '';
        document.getElementById('selectedStudentDisplay').style.display = 'none';
        if (finesDisplay) {
            finesDisplay.textContent = 'Select a student to see their fines';
            finesDisplay.className = 'form-control bg-light text-muted';
        }
    }

    document.getElementById('studentSearchInput').addEventListener('keydown', function(e) {
        if (e.key === 'Enter') {
            e.preventDefault();
            searchStudentModal();
        }
    });

    document.getElementById('manualTransactionForm').addEventListener('submit', function(e) {
        const type = document.querySelector('input[name="type"]:checked').value;
        if (type === 'settle') {
            e.preventDefault();
            const studentId = document.getElementById('studentIdInput').value;
            if (!studentId) return alert('Please select a student.');
            const form = document.createElement('form');
            form.method = 'POST';
            form.action = '/Librarian-Transactions/SettleFines';
            const input = document.createElement('input');
            input.type = 'hidden';
            input.name = 'studentId';
            input.value = studentId;
            form.appendChild(input);
            document.body.appendChild(form);
            form.submit();
        }
    });
</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>