<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Transactions Dashboard</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">

    <link rel="stylesheet" href="/styles/layout.css">
    <link rel="stylesheet" href="/styles/librarian.css">
    <link rel="stylesheet" href="/styles/librarian.transactions.css">

</head>

<body>

<%- include("partials/librarian.header.ejs") %>

<div class="container-fluid mt-4">
    <div class="transactions-container">
        <div class="transactions-header">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
                <div>
                    <h2 class="fw-bold mb-1">
                        Transactions
                    </h2>
                </div>

                <button class="btn btn-dark btn-lg rounded-4 px-4">
                    Export Report
                </button>
            </div>
        </div>


        <div class="row g-4 mb-4">
            <div class="col-md-4">
                <div class="stats-card">
                    <h6 class="stats-title">
                        Borrowed Books
                    </h6>
                    <h2 class="stats-value">
                        148
                    </h2>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stats-card">
                    <h6 class="stats-title">
                        Returned Today
                    </h6>
                    <h2 class="stats-value">
                        34
                    </h2>
                </div>
            </div>

            <div class="col-md-4">
                <div class="stats-card overdue-card">
                    <h6 class="stats-title">
                        Overdue Books
                    </h6>
                    <h2 class="stats-value">
                        12
                    </h2>
                </div>
            </div>
        </div>


        <div class="transactions-list">
            <div class="d-flex flex-column gap-3">
                <!-- Transaction -->
                <div class="transaction-item">
                    <div class="row align-items-center">
                        <div class="col-md-1 text-center">
                            <img src="https://randomuser.me/api/portraits/men/32.jpg"
                                 alt="student"
                                 class="transaction-image">
                        </div>

                        <div class="col-md-5">
                            <h5 class="transaction-name">
                                John Carter
                            </h5>
                            <p class="transaction-book">
                                Borrowed:
                                <strong>Atomic Habits</strong>
                            </p>
                            <span class="transaction-date">
                                May 20, 2026
                            </span>
                        </div>

                        <div class="col-md-3">
                            <span class="status-borrowed">
                                Borrowed
                            </span>
                        </div>

                        <div class="col-md-3">
                            <div class="transaction-actions d-flex flex-column gap-2">
                                <button class="btn btn-outline-dark">
                                    View
                                </button>
                                <button class="btn btn-outline-success">
                                    Mark Returned
                                </button>
                            </div>
                        </div>
                    </div>
                </div>


                <div class="transaction-item">
                    <div class="row align-items-center">
                        <div class="col-md-1 text-center">
                            <img src="https://randomuser.me/api/portraits/women/44.jpg"
                                 alt="student"
                                 class="transaction-image">
                        </div>


                        <div class="col-md-5">
                            <h5 class="transaction-name">
                                Sophia Williams
                            </h5>
                            <p class="transaction-book">
                                Returned:
                                <strong>Harry Potter</strong>
                            </p>
                            <span class="transaction-date">
                                May 19, 2026
                            </span>
                        </div>

                        <div class="col-md-3">
                            <span class="status-returned">
                                Returned
                            </span>
                        </div>


                        <div class="col-md-3">
                            <div class="transaction-actions d-flex flex-column gap-2">
                                <button class="btn btn-outline-dark">
                                    View
                                </button>
                                <button class="btn btn-outline-primary">
                                    Receipt
                                </button>
                            </div>
                        </div>
                    </div>
                </div>


                <div class="transaction-item">
                    <div class="row align-items-center">
                        <div class="col-md-1 text-center">
                            <img src="https://randomuser.me/api/portraits/men/75.jpg"
                                 alt="student"
                                 class="transaction-image">
                        </div>
                        <div class="col-md-5">
                            <h5 class="transaction-name">
                                Michael Reyes
                            </h5>
                            <p class="transaction-book">
                                Borrowed:
                                <strong>Rich Dad Poor Dad</strong>
                            </p>
                            <span class="transaction-date">
                                May 15, 2026
                            </span>
                        </div>

                        <div class="col-md-3">
                            <span class="status-overdue">
                                Overdue
                            </span>
                        </div>

                        <div class="col-md-3">
                            <div class="transaction-actions d-flex flex-column gap-2">
                                <button class="btn btn-outline-dark">
                                    View
                                </button>
                                <button class="btn btn-outline-danger">
                                    Send Reminder
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>