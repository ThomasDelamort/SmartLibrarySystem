<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Librarian Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="/styles/librarian.css" rel="stylesheet">
</head>
<body>

<div class="d-flex">
    <%- include("partials/librarian-sidebar.ejs") %>


    <div class="container-fluid p-4">
        <div class="topbar d-flex justify-content-between align-items-center p-3 mb-4">
            <div>
                <h2 class="fw-bold mb-0">Librarian Dashboard</h2>
            </div>
            <div class="d-flex align-items-center gap-2">
                <div class="dropdown">
                    <button class="btn dropdown-toggle" type="button"
                            data-bs-toggle="dropdown"
                            aria-expanded="false">

                        <img class="rounded-circle me-3"
                             src="/images/user.png"
                             alt="user"
                             width="40">
                    </button>

                    <ul class="dropdown-menu">
                        <li><a class="dropdown-item" href="#">My Profile</a></li>
                        <li><a class="dropdown-item" href="#">Preferences</a></li>
                        <li><a class="dropdown-item" href="#">Status</a></li>
                        <li><a class="dropdown-item" href="#">History</a></li>
                        <li><a class="dropdown-item text-danger" href="/">Log Out</a></li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="row g-4 mb-4">
            <div class="col-md-3">
                <div class="card dashboard-card p-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted">Total Books</h6>
                            <h2 class="fw-bold">24</h2>
                        </div>
                        <i class="bi bi-book-fill fs-1 text-primary"></i>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card dashboard-card p-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted">Borrowed</h6>
                            <h2 class="fw-bold">0</h2>
                        </div>
                        <i class="bi bi-arrow-repeat fs-1 text-success"></i>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card dashboard-card p-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted">Students</h6>
                            <h2 class="fw-bold">1</h2>
                        </div>
                        <i class="bi bi-people-fill fs-1 text-warning"></i>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card dashboard-card p-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted">Overdue</h6>
                            <h2 class="fw-bold">0</h2>
                        </div>
                        <i class="bi bi-exclamation-circle-fill fs-1 text-danger"></i>
                    </div>
                </div>
            </div>

        </div>


        <div class="card dashboard-card book-table p-4">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h4 class="fw-bold mb-0">Recent Borrowings</h4>

                <button class="btn btn-primary">
                    <i class="bi bi-plus-circle me-2"></i>
                    Add Borrowing
                </button>
            </div>

            <div class="table-responsive">
                <table class="table align-middle table-hover">
                    <thead class="table-dark">
                    <tr>
                        <th>Book</th>
                        <th>Student</th>
                        <th>Date Borrowed</th>
                        <th>Due Date</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                    </thead>

                    <tbody>

                    <tr>
                        <td>The Great Gatsby</td>
                        <td>John Carter</td>
                        <td>May 10, 2026</td>
                        <td>May 17, 2026</td>
                        <td>
                            <span class="badge bg-success">Returned</span>
                        </td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary">
                                View
                            </button>
                        </td>
                    </tr>

                    <tr>
                        <td>Atomic Habits</td>
                        <td>Maria Santos</td>
                        <td>May 12, 2026</td>
                        <td>May 19, 2026</td>
                        <td>
                            <span class="badge bg-warning text-dark">Borrowed</span>
                        </td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary">
                                View
                            </button>
                        </td>
                    </tr>

                    <tr>
                        <td>1984</td>
                        <td>David Cruz</td>
                        <td>May 11, 2026</td>
                        <td>May 18, 2026</td>
                        <td>
                            <span class="badge bg-danger">Overdue</span>
                        </td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary">
                                View
                            </button>
                        </td>
                    </tr>

                    </tbody>
                </table>
            </div>
        </div>
    </div>




</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
